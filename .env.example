# Backend (required)
DATABASE_URL=PASTE_YOUR_SUPABASE_DATABASE_URL_HERE

# Optional (only needed if Supabase client is used directly)
SUPABASE_URL=PASTE_YOUR_SUPABASE_URL_HERE
SUPABASE_SERVICE_ROLE_KEY=PASTE_YOUR_SERVICE_ROLE_KEY_HERE

# Authentication (required)
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
AUTH_SECRET=PASTE_A_HIGH_ENTROPY_SECRET_HERE

# Bootstrap credentials for the manager account. Consumed once by
# `python -m scripts.seed_manager`; after the account exists the password
# is stored only as a bcrypt hash in the users table and these two values
# can be removed from the .env file.
MANAGER_USERNAME=manager
MANAGER_PASSWORD=replace-with-a-12plus-char-passphrase
MANAGER_EMAIL=manager@example.com

# Email delivery for the "forgot password" flow. A Resend API key is required
# for links to actually send; without it, the server still accepts reset
# requests but prints the link to stdout so development can proceed offline.
RESEND_API_KEY=
RESEND_FROM=AGW Heating <onboarding@resend.dev>
FRONTEND_URL=http://127.0.0.1:5173

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8000