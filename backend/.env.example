# Primary database. Set to a postgresql:// URL for Supabase/managed Postgres
# or sqlite:///local.db for fully-local development.
DATABASE_URL=postgresql://user:pass@host:5432/postgres

# Supabase service credentials (optional; used by migration scripts).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_placeholder

# JWT signing key. Must be at least 32 high-entropy characters.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
AUTH_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Bcrypt work factor. Raise for production, lower for faster dev tests.
BCRYPT_COST=12

# Bootstrap manager account used by scripts/seed_manager.py.
MANAGER_USERNAME=manager
MANAGER_PASSWORD=ChangeMe!AGW-Manager-2026
MANAGER_EMAIL=ops@example.com

# Resend transactional email (password reset). Leave blank to log instead of send.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM=AGW Heating <onboarding@resend.dev>

# Public URL used in reset-email links.
FRONTEND_URL=http://127.0.0.1:5173

# Comma-separated CORS allowlist; defaults to localhost Vite dev server.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# TrOCR checkpoint overrides (point at ./data/trocr-finetuned/final after training).
TROCR_HANDWRITTEN_MODEL=microsoft/trocr-large-handwritten
TROCR_PRINTED_MODEL=microsoft/trocr-base-printed
TROCR_MAX_NEW_TOKENS=96
